PORT=3000
NODE_ENV=production

# Rate limiting
RATE_LIMIT_WINDOW_INFO_MS=60000
RATE_LIMIT_MAX_INFO=15
RATE_LIMIT_WINDOW_DOWNLOAD_MS=600000
RATE_LIMIT_MAX_DOWNLOAD=10
RATE_LIMIT_MAX_ZIP=3

# Network
REQUEST_TIMEOUT_MS=15000
MAX_ZIP_SIZE_BYTES=104857600
MAX_INDIVIDUAL_FILE_BYTES=20971520

# Threads scraping
THREADS_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36

# Optional residential / datacenter proxy (only if Meta blocks server IP)
# PROXY_URL=http://user:pass@proxy.example.com:8080
